# Konfigurace z prostředí (zkopíruj na .env a uprav). Načítá pipeline.settings.

# Cílová databáze. SQLite (dev) nebo PostgreSQL (prod).
DATABASE_URL=sqlite:///data/cs_financials.db
# DATABASE_URL=postgresql://bank:bank@localhost:5432/bank

# Zdrojový ČS xlsx pro build_db (když se nepředá argumentem).
XLSX_PATH=key_figures_q1_2026.xlsx

# CORS: "*" nebo CSV originů (např. https://app.example.com,https://admin.example.com)
ALLOWED_ORIGINS=*
